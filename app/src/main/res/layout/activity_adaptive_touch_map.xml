<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/adaptive_touch_map_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/adaptive_touch_map_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#111827" />

    <TextView
        android:id="@+id/adaptive_touch_map_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#4B5563"
        android:textSize="14sp" />

    <rkr.simplekeyboard.inputmethod.latin.AdaptiveTouchMapView
        android:id="@+id/adaptive_touch_map_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="#FFFFFF" />

</LinearLayout>
