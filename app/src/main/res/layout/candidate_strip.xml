<?xml version="1.0" encoding="utf-8"?>
<rkr.simplekeyboard.inputmethod.latin.CandidateStripView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/candidate_strip_view"
    android:layout_width="match_parent"
    android:layout_height="@dimen/config_candidate_strip_height"
    android:baselineAligned="false"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">
    <TextView
        android:id="@+id/candidate_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textSize="16sp"
        android:visibility="invisible" />
    <TextView
        android:id="@+id/candidate_2"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textSize="16sp"
        android:visibility="invisible" />
    <TextView
        android:id="@+id/candidate_3"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textSize="16sp"
        android:visibility="invisible" />
</rkr.simplekeyboard.inputmethod.latin.CandidateStripView>
